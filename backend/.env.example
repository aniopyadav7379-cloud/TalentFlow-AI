# --- App ---
APP_NAME=TalentFlow AI
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000

# --- Postgres ---
DATABASE_URL=postgresql+psycopg2://talentflow:talentflow@localhost:5432/talentflow
DATABASE_ECHO=false

# --- Qdrant ---
# "local:<path>" = embedded, no server needed (default, good for local dev).
# Set to a real server URL (e.g. http://localhost:6333) for staging/production.
QDRANT_URL=local:./storage/qdrant_data
QDRANT_API_KEY=
EMBEDDING_DIM=1536
EMBEDDING_MODEL=text-embedding-3-small

# --- OpenAI ---
# Leave empty for local dev/tests — embedding falls back to FakeEmbeddingClient
# automatically, but LLMClient/EnkryptClient require a real key to function.
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# --- Enkrypt AI ---
ENKRYPT_API_KEY=
ENKRYPT_BASE_URL=https://api.enkryptai.com
ENKRYPT_ENABLED=true

# --- Auth ---
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Storage ---
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=./storage/resumes
S3_BUCKET_NAME=

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
