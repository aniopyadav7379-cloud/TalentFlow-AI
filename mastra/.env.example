# --- Backend (this Mastra service orchestrates the existing FastAPI backend) ---
BACKEND_BASE_URL=http://localhost:8000/api/v1

# --- LLM (Mastra's model router format: "provider/model") ---
OPENAI_API_KEY=
MASTRA_MODEL=openai/gpt-4o-mini

# --- Qdrant (Mastra's OWN memory collection, same Qdrant deployment as the backend) ---
# IMPORTANT: this must be a real reachable Qdrant server URL. The backend's
# "local:<path>" embedded mode is a Python-only qdrant-client feature and is
# NOT reachable from this Node.js service — point this at the same Qdrant
# server/Qdrant Cloud instance the backend uses in that case.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
MASTRA_MEMORY_COLLECTION=mastra_memory

# --- Service ---
PORT=4111
# Frontend origin(s) allowed to call this service directly from the browser
# (the "Run via Mastra Agent" panel). Comma-separate multiple origins.
CORS_ORIGINS=http://localhost:3000
